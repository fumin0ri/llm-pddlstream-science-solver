# OpenAI API key. Get it from https://platform.openai.com/account/api-keys
#OPENAI_API_KEY=sk-1234567890abcdef1234567890abcdef # Uncomment and set your API key here

# Select which user to run the container as
UID=0
GID=0
# 0 is root user. We recommend using a non-root user so that created files are owned by the host user.
# On Linux and WSL on Windows, you can find the user ID and group ID by running the following command:
    # UID: id -u # (for user ID)
    # GID: id -g # (for group ID)
# On Mac, use the `id` command in the terminal to find the user ID and group ID.