# OpenAI API key for GPT-based backends.
# Leave it commented out if you use the default Ollama-based path.
# OPENAI_API_KEY=sk-your-key-here

# Optional: override the Ollama endpoint.
# OLLAMA_URL=http://localhost:11434/api/chat

# Optional: Hugging Face token for LOCAL_LLAMA_Chat.
# HF_TOKEN=hf_your_token_here

# Container user mapping for Docker-based runs.
UID=0
GID=0
